# ─────────────────────────────────────────────────────────────────────────────
# AI Market Regime Detection V2 — Environment Variables
# Author: Ankit Paudel | CS 4771 Machine Learning — University of Idaho
#
# Copy this file to .env and fill in the keys you have.
# The app works perfectly with ALL keys left blank — optional features
# simply won't appear on the dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required: none. The base app needs zero API keys. ────────────────────────

# ── Optional: GPT-4o plain-English commentary ────────────────────────────────
# Get a key at: https://platform.openai.com/api-keys
# Leave blank to disable — predictions still work, commentary panel is hidden.
OPENAI_API_KEY=

# ── Optional: News Sentiment panel ───────────────────────────────────────────
# Free key (100 req/day) at: https://newsapi.org/register
NEWSAPI_KEY=

# ── Optional: Reddit Mention Tracker panel ───────────────────────────────────
# Create an app at: https://www.reddit.com/prefs/apps (script type)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=MarketRegimeV2/1.0

# ── Optional: Analyst Data panel (earnings, target price, consensus) ─────────
# Free key (25 req/day) at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=
